DJANGO_SECRET_KEY=请替换为长度不少于32位的安全随机字符串
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,backend
DJANGO_CORS_ALLOW_ALL=true

DB_ENGINE=sqlite
DB_NAME=db.sqlite3
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=archive
DB_PASSWORD=archive123456

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=noreply@asd-system.local

BACKEND_LOG_LEVEL=INFO
BACKEND_LOG_DIR=logs
BACKEND_LOG_ROTATION_WHEN=midnight
BACKEND_LOG_ROTATION_INTERVAL=1
BACKEND_LOG_BACKUP_COUNT=14
SYSTEM_STORAGE_WARNING_PERCENT=85
SYSTEM_STORAGE_CRITICAL_PERCENT=95

